NODE_ENV=development

POSTGRES_DB=inventory_db
POSTGRES_USER=inventory_user
POSTGRES_PASSWORD=inventory_password

# Local Docker Postgres (no TLS). For production use a managed DB URL with ?sslmode=require
DATABASE_URL=postgresql://inventory_user:inventory_password@localhost:5433/inventory_db?schema=public
# Optional locally (defaults to DATABASE_URL). On Neon: set to the direct host (no -pooler),
# or omit and the app will strip "-pooler" from DATABASE_URL automatically.
DIRECT_URL=postgresql://inventory_user:inventory_password@localhost:5433/inventory_db?schema=public

REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=change_this_access_secret_min_16
JWT_REFRESH_SECRET=change_this_refresh_secret_min_16

# Required when NODE_ENV=production (comma-separated browser origins for cookie/CORS auth)
# Must include every SPA origin exactly (scheme + host, no trailing slash):
# CORS_ORIGIN=https://ehsinventory.in,https://www.ehsinventory.in
CORS_ORIGIN=

# Frontend (web): leave VITE_API_URL unset or set to /api so auth cookies are same-origin
# via nginx reverse proxy. Do NOT point the SPA at https://api.ehsinventory.in when cookies
# are first-party on ehsinventory.in — that recreates the iOS Safari login loop.
# VITE_API_URL=/api


BACKEND_PORT=3000
WEB_PORT=5173

# Brevo transactional email (required in production for password-reset OTPs)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
# OTP for undeliverable login emails (e.g. admin@inventory.local) is sent here
RECOVERY_EMAIL=
# Local only: set to 1 to log OTP to console when Brevo is missing/fails (never in production)
# BREVO_DEV_FALLBACK=1
