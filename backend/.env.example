PORT=3000
NODE_ENV=development

# Critical — required at startup
DATABASE_URL=postgresql://inventory_user:inventory_password@localhost:5433/inventory_db?schema=public
# Required by Prisma (migrations). Locally use the same value as DATABASE_URL.
# On Neon: use the direct host (no "-pooler" in the hostname).
DIRECT_URL=postgresql://inventory_user:inventory_password@localhost:5433/inventory_db?schema=public
JWT_ACCESS_SECRET=change_this_access_secret_min_16
JWT_REFRESH_SECRET=change_this_refresh_secret_min_16
REDIS_URL=redis://localhost:6379

# Required in production (comma-separated browser origins for cookie/CORS auth)
# Example: https://app.example.com
CORS_ORIGIN=

# Production DB TLS: include sslmode=require in DATABASE_URL and DIRECT_URL, or set DATABASE_SSL=disable
# only for private networks without TLS (not recommended).
# DATABASE_SSL=disable

# Brevo transactional email (password-reset OTP). Do not use a custom SMTP= name — the app reads BREVO_*.
BREVO_API_KEY=
# Must be a sender/domain verified in the Brevo dashboard.
BREVO_SENDER_EMAIL=
# Receives OTPs for non-deliverable login emails (e.g. @inventory.local). Also CC'd for real emails.
RECOVERY_EMAIL=

# Optional — query SQL logging is disabled when NODE_ENV=production
SLOW_QUERY_MS=200
